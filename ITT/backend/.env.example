# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Neon PostgreSQL (replace with your own Neon connection string)
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer / Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@invest.com

# Twilio SMS (optional — leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# File Upload
UPLOAD_MAX_SIZE=10485760

# Default CEO seed account
CEO_EMAIL=ceo@invest.com
CEO_PASSWORD=Admin@123456
CEO_USERNAME=CEO
